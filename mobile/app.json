{
  "expo": {
    "name": "Flixhome",
    "slug": "flixhome",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.flixhome.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      }
    },
    "scheme": "flixhome",
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-video",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "003e6f97-72d9-49d4-a9aa-2360f01b3fcf"
      }
    }
  }
}
