{
  "expo": {
    "name": "Flixhome",
    "slug": "flixhome",
    "version": "1.0.5",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.flixhome.app",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.flixhome.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "flixhome",
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-video",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a0a0a",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77d031ac-6342-4017-8641-8376b1476a3b"
      }
    },
    "owner": "victor57898"
  }
}
