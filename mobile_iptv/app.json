{
  "expo": {
    "name": "Flixhome IPTV",
    "slug": "flixhome-iptv",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.flixhome.iptv",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.flixhome.iptv",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "scheme": "flixhome-iptv",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-screen-orientation",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a0a0a",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}